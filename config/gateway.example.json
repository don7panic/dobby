{
  "extensions": {
    "allowList": [
      {
        "package": "@im-agent-gateway/provider-pi",
        "enabled": true
      },
      {
        "package": "@im-agent-gateway/connector-discord",
        "enabled": true
      }
    ]
  },
  "providers": {
    "defaultProviderId": "pi.main",
    "instances": {
      "pi.main": {
        "contributionId": "provider.pi",
        "config": {
          "provider": "custom-openai",
          "model": "example-model",
          "thinkingLevel": "off",
          "modelsFile": "./models.custom.json"
        }
      }
    }
  },
  "connectors": {
    "instances": {
      "discord.main": {
        "contributionId": "connector.discord",
        "config": {
          "botTokenEnv": "DISCORD_BOT_TOKEN",
          "allowDirectMessages": true,
          "allowedGuildIds": []
        }
      }
    }
  },
  "sandboxes": {
    "defaultSandboxId": "host.builtin",
    "instances": {}
  },
  "routing": {
    "defaultRouteId": "projectA",
    "channelMap": {
      "discord.main": {
        "YOUR_DISCORD_CHANNEL_ID_A": "projectA"
      }
    },
    "routes": {
      "projectA": {
        "projectRoot": "/Users/you/workspace/project-a",
        "tools": "full",
        "systemPromptFile": "",
        "allowMentionsOnly": true,
        "maxConcurrentTurns": 1,
        "providerId": "pi.main",
        "sandboxId": "host.builtin"
      }
    }
  },
  "data": {
    "rootDir": "./data",
    "dedupTtlMs": 604800000
  }
}
