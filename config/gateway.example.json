{
  "extensions": {
    "allowList": [
      {
        "package": "@dobby.ai/provider-pi",
        "enabled": true
      },
      {
        "package": "@dobby.ai/connector-discord",
        "enabled": true
      },
      {
        "package": "@dobby.ai/provider-claude-cli",
        "enabled": false
      }
    ]
  },
  "providers": {
    "defaultProviderId": "pi.main",
    "instances": {
      "pi.main": {
        "contributionId": "provider.pi",
        "config": {
          "provider": "custom-openai",
          "model": "example-model",
          "thinkingLevel": "off",
          "modelsFile": "./models.custom.json"
        }
      }
    }
  },
  "connectors": {
    "instances": {
      "discord.main": {
        "contributionId": "connector.discord",
        "config": {
          "botName": "dobby-main",
          "botToken": "REPLACE_WITH_DISCORD_BOT_TOKEN",
          "botChannelMap": {
            "YOUR_DISCORD_CHANNEL_ID_A": "projectA"
          },
          "reconnectStaleMs": 60000,
          "reconnectCheckIntervalMs": 10000
        }
      }
    }
  },
  "sandboxes": {
    "defaultSandboxId": "host.builtin",
    "instances": {}
  },
  "routing": {
    "defaultRouteId": "projectA",
    "routes": {
      "projectA": {
        "projectRoot": "/Users/you/workspace/project-a",
        "tools": "full",
        "systemPromptFile": "",
        "allowMentionsOnly": true,
        "maxConcurrentTurns": 1,
        "providerId": "pi.main",
        "sandboxId": "host.builtin"
      }
    }
  },
  "_examples": {
    "providers": {
      "instances": {
        "claude-cli.main": {
          "contributionId": "provider.claude-cli",
          "config": {
            "model": "claude-sonnet-4-5",
            "maxTurns": 20,
            "command": "claude",
            "commandArgs": [],
            "authMode": "auto",
            "permissionMode": "bypassPermissions",
            "streamVerbose": true
          }
        }
      }
    },
    "routing": {
      "routes": {
        "projectA": {
          "providerId": "claude-cli.main"
        }
      }
    }
  },
  "data": {
    "rootDir": "./data",
    "dedupTtlMs": 604800000
  }
}
