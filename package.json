{
  "name": "dobby",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord-first local agent gateway built on pi packages",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:local": "node --env-file-if-exists=.env --import tsx --watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:local": "node --env-file-if-exists=.env dist/src/main.js",
    "check": "tsc --noEmit",
    "plugins:install": "node scripts/local-extensions.mjs install --config ./config/gateway.json",
    "plugins:check": "node scripts/local-extensions.mjs check --config ./config/gateway.json",
    "plugins:build": "node scripts/local-extensions.mjs build --config ./config/gateway.json",
    "extensions:install:local": "node scripts/local-extensions.mjs install-store --config ./config/gateway.json",
    "extensions:list:local": "node scripts/local-extensions.mjs list-store --config ./config/gateway.json",
    "plugins:setup:local": "node scripts/local-extensions.mjs setup --config ./config/gateway.json"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.53.0",
    "pino": "^9.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
