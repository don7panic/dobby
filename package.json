{
  "name": "im-agent-gateway",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Discord-first local agent gateway built on pi packages",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "dev:local": "node --env-file-if-exists=.env --import tsx --watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:local": "node --env-file-if-exists=.env dist/src/main.js",
    "check": "tsc --noEmit"
  },
  "dependencies": {
    "@im-agent-gateway/connector-discord": "file:plugins/connector-discord",
    "@im-agent-gateway/plugin-sdk": "file:plugins/plugin-sdk",
    "@im-agent-gateway/provider-claude": "file:plugins/provider-claude",
    "@im-agent-gateway/provider-pi": "file:plugins/provider-pi",
    "@im-agent-gateway/sandbox-core": "file:plugins/sandbox-core",
    "@mariozechner/pi-agent-core": "^0.53.0",
    "@mariozechner/pi-ai": "^0.53.0",
    "@mariozechner/pi-coding-agent": "^0.53.0",
    "pino": "^9.6.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2"
  }
}
